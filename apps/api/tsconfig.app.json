{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "nodenext",
    "types": [
      "node"
    ],
    "moduleResolution": "nodenext",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "strict": true,
    "rootDir": "../../"
  },
  "include": ["src/**/*.ts", "../../libs/models/src/index.ts", "../../libs/models/src/lib/models.ts"],
  "exclude": ["src/**/*.spec.ts", "jest.config.js"]
}
