{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "desktop",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../dist/apps/desktop",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Système de Santé",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "additionalBrowserArgs": "--renderer-process-limit=1 --js-flags=\"--max-old-space-size=500\" --disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection"
      }
    ],
    "security": {
      "csp": "default-src 'none'; connect-src 'self' http://localhost:* ws://localhost:* https://*.abdm.gov.in; img-src 'self' data: http://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self';",
      "capabilities": []
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "windows": {
      "webviewInstallMode": {
        "type": "fixedRuntime",
        "path": "webview2_109"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
