  "scripts": {
    "start": "nx serve",
    "start:api": "nx serve api",
    "start:desktop": "nx serve desktop",
    "start:mobile": "nx serve mobile",
    "start:all": "nx run-many --target=serve --all",
    "docker:up": "docker compose --file infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose --file infra/docker/docker-compose.yml down",
    "db:push": "npx prisma generate && npx prisma db push",
    "link:workspace": "npm run link:workspace:models && npm run link:workspace:insurance && npm run link:workspace:cornerstone",
    "link:workspace:models": "cd libs/models && npm link && cd ../../apps/api && npm link @systeme-sante/models && cd ../../apps/mobile && npm link @systeme-sante/models",
    "link:workspace:insurance": "cd libs/insurance-engine && npm link && cd ../../apps/api && npm link @systeme-sante/insurance-engine",
    "link:workspace:cornerstone": "cd libs/cornerstone-integration && npm link && cd ../../apps/api && npm link @systeme-sante/cornerstone-integration",
    "test:all": "npx nx run-many --target=test --all",
    "test:api": "npx nx test api",
    "test:mobile": "npx nx test mobile",
    "lint": "npx nx run-many --target=lint --all",
    "typecheck": "npx nx run-many --target=typecheck --all",
    "clean": "npx nx run-many --target=clean --all",
    "build:all": "npx nx run-many --target=build --all",
    "build:api": "npx nx build api",
    "build:mobile": "npx nx build mobile",
    "build:portail-pwa": "npx nx build portail-pwa",
    "serve:api": "npx nx serve api",
    "serve:mobile": "npx nx serve mobile",
    "serve:portail-pwa": "npx nx serve portail-pwa"
  },
