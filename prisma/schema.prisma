generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  PHARMACIST
  LAB_TECH
}

enum ActionType {
  READ
  CREATE
  UPDATE
  DELETE
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  role        Role     @default(DOCTOR)
  totpSecret  String?  @map("totp_secret") // Base32 encoded secret for offline MFA
  mfaEnabled  Boolean  @default(false) @map("mfa_enabled")
  backupCodes String[] @map("backup_codes") // Array of hashed backup codes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  auditLogs    AuditLog[]
  dpdpaConsent DpdpaConsent[]
}

model Patient {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  dateOfBirth DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Sync Status Fields
  status      String    @default("created") @map("_status") // synced, created, updated, deleted
  deletedAt   DateTime? @map("deleted_at")

  auditLogs     AuditLog[]
  dpdpaConsent  DpdpaConsent[]
  visits        Visit[]
  vitals        Vital[]
  prescriptions Prescription[]
  invoices      Invoice[]
  notifications NotificationStatus[]
}

model Visit {
  id        String    @id @default(uuid())
  patientId String    @map("patient_id")
  date      DateTime
  notes     Bytes? // Will store Yjs Binary Updates (Uint8Array)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Sync Status Fields
  status    String    @default("created") @map("_status")
  deletedAt DateTime? @map("deleted_at")

  patient       Patient        @relation(fields: [patientId], references: [id])
  prescriptions Prescription[]
}

model Vital {
  id            String    @id @default(uuid())
  patientId     String    @map("patient_id")
  bloodPressure String?   @map("blood_pressure")
  heartRate     Int?      @map("heart_rate")
  temperature   Float?
  recordedAt    DateTime  @map("recorded_at")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // Sync Status Fields
  status        String    @default("created") @map("_status")
  deletedAt     DateTime? @map("deleted_at")

  patient Patient @relation(fields: [patientId], references: [id])
}

model Prescription {
  id             String    @id @default(uuid())
  visitId        String    @map("visit_id")
  patientId      String    @map("patient_id")
  medicationName String    @map("medication_name")
  dosage         String
  instructions   String?
  prescribedAt   DateTime  @map("prescribed_at")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // Sync Status Fields
  status         String    @default("created") @map("_status")
  deletedAt      DateTime? @map("deleted_at")

  visit   Visit   @relation(fields: [visitId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])
}

model AuditLog {
  id              String     @id @default(uuid())
  userId          String     @map("user_id")
  actionType      ActionType @map("action_type")
  resourceId      String     @map("resource_id")
  phiDataAccessed Json       @map("phi_data_accessed")
  ipAddress       String?    @map("ip_address")
  timestamp       DateTime   @default(now())

  user      User    @relation(fields: [userId], references: [id])
  patient   Patient @relation(fields: [patientId], references: [id])
  patientId String  @map("patient_id")

  @@index([patientId, timestamp])
  @@index([userId, timestamp])
  @@map("audit_logs")
}

model DpdpaConsent {
  id        String   @id @default(uuid())
  patientId String   @map("patient_id")
  userId    String   @map("user_id")
  grantedAt DateTime @default(now())
  expiresAt DateTime
  purpose   String

  patient Patient @relation(fields: [patientId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("dpdpa_consents")
}

model Invoice {
  id             String   @id @default(uuid())
  idempotencyKey String   @unique @map("idempotency_key") // Essentiel pour éviter la double facturation
  patientId      String   @map("patient_id")
  currency       String   @default("INR") // INR, EUR, XOF
  subtotalCents  Int      @map("subtotal_cents") // Toujours en entiers
  taxCents       Int      @map("tax_cents")
  totalCents     Int      @map("total_cents")
  status         String   @default("UNPAID") // UNPAID, PAID, CANCELLED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("invoices")
}

model Supplier {
  id           String   @id @default(uuid())
  name         String   @unique
  contactEmail String?  @map("contact_email")
  contactPhone String?  @map("contact_phone")
  leadTimeDays Int      @default(7) @map("lead_time_days") // Délai de livraison habituel
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  inventoryItems InventoryItem[]
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id             String   @id @default(uuid())
  supplierId     String   @map("supplier_id")
  status         String   @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, SENT, RECEIVED
  idempotencyKey String?  @unique @map("idempotency_key")
  totalCents     Int      @default(0) @map("total_cents")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String @id @default(uuid())
  purchaseOrderId String @map("purchase_order_id")
  inventoryItemId String @map("inventory_item_id")
  quantity        Int
  unitPriceCents  Int    @map("unit_price_cents") // Prix d'achat au moment de la commande

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@map("purchase_order_items")
}

model InventoryItem {
  id              String   @id @default(uuid())
  name            String   @unique
  category        String   @default("GENERAL") // ANTI_MALARIAL, ANTIBIOTIC, ANALGESIC, GENERAL
  currentQuantity Int      @default(0) @map("current_quantity")
  unitPriceCents  Int      @map("unit_price_cents") // Prix de vente unitaire
  supplierId      String?  @map("supplier_id")
  moq             Int      @default(1) // Minimum Order Quantity
  leadTimeDays    Int?     @map("lead_time_days")
  isActive        Boolean  @default(true) @map("is_active")
  updatedAt       DateTime @updatedAt

  supplier           Supplier?              @relation(fields: [supplierId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  transactions       InventoryTransaction[]

  @@map("inventory_items")
}

model InventoryTransaction {
  id             String   @id @default(uuid())
  itemId         String   @map("item_id")
  type           String // DISPENSE, RECEIPT, ADJUSTMENT
  quantityChange Int      @map("quantity_change")
  timestamp      DateTime @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id])

  @@map("inventory_transactions")
}

model NotificationStatus {
  id             String   @id @default(uuid())
  patientId      String   @map("patient_id")
  channel        String   @default("WHATSAPP") // WHATSAPP, SMS
  status         String   @default("QUEUED") // QUEUED, SENT, DELIVERED, READ, FAILED
  messagePayload String   @map("message_payload") // Contenu textuel ou template
  externalId     String?  @map("external_id") // ID renvoyé par l'API Meta/Twilio
  failCount      Int      @default(0) @map("fail_count")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("notification_statuses")
}
