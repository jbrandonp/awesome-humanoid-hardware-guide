{
  "name": "@systeme-sante/cornerstone-integration",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "react": "^19.1.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "nx": {
    "name": "cornerstone-integration",
    "targets": {
      "lint": {
        "executor": "@nx/eslint:lint",
        "options": {
          "eslintConfig": ".eslintrc.js",
          "lintFilePatterns": ["libs/cornerstone-integration/**/*.ts"]
        }
      }
    }
  }
}