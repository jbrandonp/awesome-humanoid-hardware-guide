# ============================================================================
# Configuration d'environnement - Système de Santé Résilient (Offline-First)
# ============================================================================
# Copier ce fichier en .env et remplir les valeurs selon votre environnement
# ============================================================================

# --- SECURITY & AUTHENTICATION ---
JWT_SECRET="change-me-to-a-secure-random-string-at-least-32-chars"
JWT_REFRESH_SECRET="change-me-to-a-secure-random-string-at-least-32-chars"
TOKEN_ENCRYPTION_KEY="change-me-to-a-secure-32-byte-random-string"
SESSION_TIMEOUT_MINUTES="30"
PASSWORD_SALT_ROUNDS="12"

# --- DATABASE CONNECTIONS ---
# PostgreSQL (Prisma) - Base de données relationnelle principale
DATABASE_URL="postgresql://user:password@localhost:5432/medical_system"
# MongoDB (Mongoose) - Dossiers cliniques, documents non structurés
MONGO_URL="mongodb://localhost:27017/medical_clinical"
# Redis - Cache, sessions, files d'attente
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""  # Optionnel
REDIS_DB="0"

# --- SERVER CONFIGURATION ---
PORT="3000"
NODE_ENV="development"
ALLOWED_ORIGINS="http://localhost:4200,tauri://localhost,http://tauri.localhost,http://localhost:8081,http://localhost:3001"
API_GLOBAL_PREFIX="api"
BODY_LIMIT_MB="50"

# --- FILE STORAGE & MEDIA ---
# S3/MinIO pour PACS (images DICOM)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="pacs-images"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="true"

# --- EXTERNAL SERVICES ---
# HL7 MLLP Server
HL7_PORT="2575"
HL7_HOST="localhost"

# WhatsApp Business API (Meta)
WHATSAPP_PHONE_ID=""           # ID du téléphone métier
WHATSAPP_ACCESS_TOKEN=""       # Token d'accès API
WHATSAPP_WEBHOOK_VERIFY_TOKEN="medical-verify-token-change-me"
WHATSAPP_API_VERSION="v18.0"

# ABDM (Inde - Ayushman Bharat Digital Mission)
ABDM_BASE_URL="https://dev.abdm.gov.in/api"
ABDM_CLIENT_ID=""
ABDM_CLIENT_SECRET=""
ABDM_ENCRYPTION_KEY=""

# DeepSeek AI Configuration (pour l'assistance médicale)
MODEL_PROVIDER="openai"
MODEL_NAME="deepseek-chat"
OPENAI_BASE_URL="https://api.deepseek.com"
OPENAI_API_KEY="your-deepseek-api-key-here"

# --- AI & PROCESSING SERVICES ---
# Whisper.cpp pour la transcription audio
WHISPER_BIN_PATH="./bin/whisper.cpp/main"
WHISPER_MODEL_PATH="./models/ggml-medium.en-q8_0.bin"
WHISPER_THREADS="4"

# OCR Configuration (Tesseract)
TESSERACT_PATH="C:\\Program Files\\Tesseract-OCR\\tesseract.exe"  # Windows
# TESSERACT_PATH="/usr/bin/tesseract"  # Linux/Mac

# --- QUEUE & BACKGROUND JOBS ---
BULLMQ_REDIS_HOST="localhost"
BULLMQ_REDIS_PORT="6379"
BULLMQ_REDIS_DB="1"

# --- ENCRYPTION & KEY MANAGEMENT ---
DATA_ENCRYPTION_KEY_VERSION="1"
KEY_ROTATION_DAYS="90"

# --- LOGGING & MONITORING ---
LOG_LEVEL="info"
LOG_FORMAT="json"
SENTRY_DSN=""  # Pour le monitoring d'erreurs
PROMETHEUS_PORT="9090"

# --- DEVELOPMENT & DEBUG ---
DEBUG="medical:*"
PRISMA_LOG_QUERIES="false"
MONGODB_DEBUG="false"
REDIS_DEBUG="false"

# --- FEATURE TOGGLES ---
ENABLE_WHISPER="true"
ENABLE_PACS_INDEXER="true"
ENABLE_ABDM_SYNC="false"
ENABLE_WHATSAPP_NOTIFICATIONS="false"
ENABLE_EPIDEMIOLOGY_TICKER="true"
ENABLE_DRUG_INTERACTION_CHECKS="true"

# ============================================================================
# NOTES IMPORTANTES :
# ============================================================================
# 1. PostgreSQL : Créer la base de données 'medical_system' avant démarrage
#    Commandes : 
#    - createdb medical_system
#    - npx prisma migrate deploy
#
# 2. MongoDB : Démarrer avec `mongod` ou via Docker
#
# 3. Redis : Démarrer avec `redis-server` ou via Docker
#
# 4. MinIO (S3) : Pour le stockage PACS
#    docker run -p 9000:9000 -p 9001:9001 minio/minio server /data --console-address ":9001"
#
# 5. Whisper.cpp : Télécharger et compiler depuis https://github.com/ggerganov/whisper.cpp
#    Placer le binaire dans ./bin/whisper.cpp/main
#
# 6. Modèles Whisper : Télécharger depuis https://huggingface.co/ggerganov/whisper.cpp
#    Exemple : ggml-medium.en-q8_0.bin dans ./models/
#
# 7. Tesseract OCR : Installer selon votre OS
#    - Windows : https://github.com/UB-Mannheim/tesseract/wiki
#    - macOS : brew install tesseract
#    - Linux : sudo apt install tesseract-ocr
# ============================================================================